<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 0; height: auto; background-image: none; width: auto; -unity-background-scale-mode: scale-to-fit; -unity-slice-bottom: initial; -unity-slice-top: initial; -unity-slice-right: initial; flex-direction: column; -unity-slice-left: initial; -unity-slice-scale: initial; flex-wrap: nowrap; flex-shrink: 0; padding-left: 10px; padding-right: 10px; padding-top: 10px;">
        <ui:Label tabindex="-1" text="Default Panel" parse-escape-sequences="true" display-tooltip-when-elided="true" name="DefaultTitle" />
        <ui:VisualElement name="DefaultSettings" style="flex-grow: 1; padding-left: 25px;">
            <ui:Toggle label="Enable/Disable" name="IsOpen" style="top: auto; margin-top: 0; margin-left: 2px;" />
            <ui:DropdownField label="Initial Position" name="StartPosition" />
            <ui:VisualElement name="TranslateMode" style="flex-grow: 1; padding-left: 25px;" />
        </ui:VisualElement>
        <ui:VisualElement name="TranslateMode" style="flex-grow: 1; padding-left: 25px;">
            <uie:ObjectField label="Input Actions" name="InputActionAsset" />
        </ui:VisualElement>
        <ui:Label tabindex="-1" text="Console Panel" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ConsoleTitle" />
        <ui:VisualElement name="ConsoleSettings" style="flex-grow: 1; padding-left: 25px;">
            <ui:SliderInt label="Maximum Count" name="MaxInfoCount" high-value="1000" show-input-field="true" low-value="500" />
        </ui:VisualElement>
        <ui:Label tabindex="-1" text="Inspector Panel" parse-escape-sequences="true" display-tooltip-when-elided="true" name="InspectorTitle" />
        <ui:VisualElement name="ConsoleSettings" style="flex-grow: 1; padding-left: 25px;">
            <ui:Slider label="WorldPositionStep" high-value="10" low-value="0" picking-mode="Ignore" show-input-field="true" name="WorldPositionStep" />
            <ui:Slider label="LocalPositionStep" high-value="10" low-value="0" picking-mode="Ignore" show-input-field="true" name="LocalPositionStep" />
            <ui:Slider label="WorldRotationStep" high-value="90" low-value="0" picking-mode="Ignore" show-input-field="true" name="WorldRotationStep" />
            <ui:Slider label="LocalRotationStep" high-value="90" low-value="0" picking-mode="Ignore" show-input-field="true" name="LocalRotationStep" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
